{
  "buildCommand": "npm run build --workspace client && mkdir -p dist && cp -r client/dist/* dist/",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}
