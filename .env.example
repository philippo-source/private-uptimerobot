NODE_ENV=development
PORT=4000
DB_PROVIDER=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/uptimerobot
DATABASE_URL_MONGO=mongodb+srv://user:password@cluster.mongodb.net/uptimerobot
SUPPORT_EMAIL=support@example.com

# SMTP settings used for down alerts.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# SMTP_EMAIL and SMTP_PASSWORD are also supported aliases for SMTP_USER and SMTP_PASS.
SMTP_FROM="Uptime Monitor <alerts@example.com>"

# Optional frontend override. In dev the Vite proxy already points /api to the backend.
VITE_API_URL=

# Global Application Authentication
APP_USERNAME=admin
APP_PASSWORD=demo